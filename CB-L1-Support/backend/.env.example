# Copy to backend/.env for local development. NEVER commit the real .env —
# it's already excluded via backend/.gitignore. On Render, set these as
# dashboard environment variables instead (see render.yaml).

# ── JIRA (used only when rebuilding the knowledge base offline) ──
JIRA_URL=https://honeywell.atlassian.net
JIRA_USERNAME=
JIRA_API_TOKEN=

# ── LLM provider switch: "azure" | "github" | "copilot" ──
LLM_PROVIDER=github
EMBED_PROVIDER=github
USE_LLM=true
USE_AZURE_OPENAI=false

# ── GitHub Models (used when LLM_PROVIDER / EMBED_PROVIDER = github) ──
GITHUB_TOKEN=
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com

# ── GitHub Copilot API (used when LLM_PROVIDER = copilot) ──
COPILOT_TOKEN=
COPILOT_API_ENDPOINT=https://api.githubcopilot.com
COPILOT_INTEGRATION_ID=copilot-developer-cli

# ── Azure OpenAI (only needed if LLM_PROVIDER/RAG_LLM_PROVIDER = azure) ──
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# ── Document-RAG pipeline (rag_docs) ──
USE_RAG_DOCS=true
RAG_LLM_PROVIDER=github
RAG_EMBED_PROVIDER=github
RAG_CHAT_MODEL=gpt-4o
RAG_EMBED_MODEL=text-embedding-3-large
RAG_TOP_K=6
RAG_TIMEOUT=60
QDRANT_URL=
QDRANT_API_KEY=
# Documentation-RAG collection (chunks of parsed PDFs).
QDRANT_COLLECTION=
# Defect knowledge-base collection (chunks of historical Jira defects) — SAME
# Qdrant cluster as QDRANT_COLLECTION above, kept in a separate collection.
DEFECT_QDRANT_COLLECTION=defect

# On-demand PDF ingestion (header upload button): LlamaParse cloud API key —
# free tier at https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=

# ── Safety toggles ──
MASK_SENSITIVE_DATA=true
CHATBOT_EXCLUDE_CANCELLED=true

# ── Server (local dev only — Render sets $PORT automatically) ──
SERVER_HOST=0.0.0.0
SERVER_PORT=5100
